<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Civic Setu Jharkhand</title>

  <!-- Tailwind CSS + Remix Icon -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    #map {
      height: 100%;
      width: 100%;
      z-index: 0;
    }
    .gov-shadow {
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }
  </style>
</head>
<body class="bg-gray-100 font-sans h-screen w-screen overflow-hidden">

  <div class="flex h-full w-full">
    <!-- Sidebar -->
    <aside class="w-72 bg-[#1B2A49] text-white flex flex-col justify-between p-6 gov-shadow">
      <div class="flex flex-col items-center">
        <img src="./image1.jpg" alt="Logo" class="w-24 h-24 rounded-full object-cover mb-4 border-4 border-white shadow-md" onerror="this.src='https://via.placeholder.com/100'" />
        <h1 class="text-lg font-bold text-center border-b border-white pb-2 mb-4">CIVIC SETU JHARKHAND</h1>

        <!-- Navigation Buttons -->
        <nav class="space-y-3 w-full">
          <a href="newprob.ejs" class="block bg-[#2E3A59] hover:bg-[#3F4C6E] py-2 px-4 rounded transition">New Incoming Problems</a>
          <a href="pendingprob.ejs" class="block bg-[#2E3A59] hover:bg-[#3F4C6E] py-2 px-4 rounded transition">Pending Problems</a>
          <a href="resolvedprob.ejs" class="block bg-[#2E3A59] hover:bg-[#3F4C6E] py-2 px-4 rounded transition">Resolved Problems</a>
          <a href="heatmap.html" class="block bg-[#2E3A59] hover:bg-[#3F4C6E] py-2 px-4 rounded transition">Heatmap</a>
          <a href="acknowledge.ejs" class="block bg-[#2E3A59] hover:bg-[#3F4C6E] py-2 px-4 rounded transition">Acknowledgement</a>
        </nav>
      </div>

      <!-- Bottom Login/Register -->
      <div class="flex flex-col gap-2">
        <a href="login-CS.ejs" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow-md text-center">Login</a>
        <a href="register.ejs" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded shadow-md text-center">Register</a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 relative">
      <!-- Map -->
      <div id="map"></div>

      <!-- Notification Bell -->
      <a href="notification.html" class="absolute top-4 right-4 z-10">
        <div class="relative">
          <i class="ri-notification-3-line text-3xl text-gray-800 hover:text-yellow-500 cursor-pointer"></i>
          <span class="absolute -top-1 -right-2 bg-red-600 text-xs px-1 rounded-full text-white">3</span>
        </div>
      </a>
    </main>
  </div>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    const map = L.map('map').setView([23.6102, 85.2799], 8); // Ranchi

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
    }).addTo(map);

    L.marker([23.6102, 85.2799]).addTo(map)
      .bindPopup('Civic Setu HQ')
      .openPopup();
  </script>
</body>
</html>