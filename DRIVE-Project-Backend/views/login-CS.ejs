<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login</title>
  <link href="https://cdn.tailwindcss.com" rel="stylesheet" />
</head>
<body class="bg-gray-100 text-gray-800">
  <header class="bg-[#1B2A49] text-white p-4 text-center text-xl font-semibold">Civic Setu Jharkhand – Login</header>
  <main class="p-6 max-w-md mx-auto">
    <form class="space-y-4">
      <input type="text" placeholder="Username" class="w-full p-2 border border-gray-300 rounded" />
      <input type="password" placeholder="Password" class="w-full p-2 border border-gray-300 rounded" />
      <button class="bg-blue-600 text-white px-4 py-2 rounded w-full">Login</button>
    </form>
  </main>
</body>
</html>