<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Acknowledgement</title>
  <link href="https://cdn.tailwindcss.com" rel="stylesheet" />
</head>
<body class="bg-gray-100 text-gray-800">
  <header class="bg-[#1B2A49] text-white p-4 text-center text-xl font-semibold">Civic Setu Jharkhand – Acknowledgement & Progress</header>
  <main class="p-6">
    <p class="mb-4">Track progress of civic issue resolutions:</p>
    <table class="table-auto w-full border border-gray-300">
      <thead class="bg-gray-200">
        <tr>
          <th class="px-4 py-2">Issue</th>
          <th class="px-4 py-2">Location</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2">Assigned Worker</th>
          <th class="px-4 py-2">Last Updated</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="px-4 py-2">Broken Manhole</td>
          <td class="px-4 py-2">Sector 9</td>
          <td class="px-4 py-2">In Progress</td>
          <td class="px-4 py-2">Rajesh Kumar</td>
          <td class="px-4 py-2">2025-09-19</td>
        </tr>
      </tbody>
    </table>
  </main>
</body>
</html>